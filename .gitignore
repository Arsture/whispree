.DS_Store
.AppleDouble
.LSOverride
._*
*.swp
*.lock
profile

# AI / Tooling
.sisyphus/
.omc/
.claude/

# IDE
*.idea/
*.vscode/

# Python
__pycache__/
*.pyc
.venv/
*.egg-info/
dist/

# ML Models
*.npz
*.bin
*.gguf
*.mlmodel
mlx_models/
.cache/

# Archives & Distribution
*.dmg
*.zip
*.tar.gz

# Docs (internal planning/handoff)
docs/
.omx/

# Public docs site (docs-site/) — Astro Starlight on Vercel
node_modules/
docs-site/node_modules/
docs-site/.astro/
docs-site/dist/
docs-site/.vercel/

# The `docs/` rule above also matches docs-site/src/content/docs/ — re-include
# the public docs content so it stays tracked.
!docs-site/src/content/docs/
!docs-site/src/content/docs/**
# ...but the broad re-include above would also re-track tooling/state or junk that
# happens to land under the content dir. Keep those ignored.
docs-site/src/content/docs/**/.omc/
docs-site/src/content/docs/**/.DS_Store
