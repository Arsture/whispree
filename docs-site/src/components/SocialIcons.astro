---
/*
 * Override of Starlight's header SocialIcons.
 * Renders a single GitHub button that (1) opens the repo in a NEW TAB and
 * (2) shows the live star count fetched from the GitHub API (cached in
 * sessionStorage with a short TTL so navigation doesn't hammer the API).
 */
const repo = 'Arsture/whispree';
---

<a
  class="wh-gh"
  href={`https://github.com/${repo}`}
  target="_blank"
  rel="noopener noreferrer"
  aria-label={`Star ${repo} on GitHub — opens in a new tab`}
>
  <svg class="wh-gh-mark" viewBox="0 0 16 16" width="16" height="16" aria-hidden="true">
    <path fill="currentColor" d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82a7.6 7.6 0 0 1 2-.27c.68 0 1.36.09 2 .27 1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.013 8.013 0 0 0 16 8c0-4.42-3.58-8-8-8Z"/>
  </svg>
  <svg class="wh-gh-star" viewBox="0 0 16 16" width="13" height="13" aria-hidden="true">
    <path fill="currentColor" d="M8 .25a.75.75 0 0 1 .673.418l1.882 3.815 4.21.612a.75.75 0 0 1 .416 1.279l-3.046 2.97.719 4.192a.75.75 0 0 1-1.088.791L8 12.347l-3.766 1.98a.75.75 0 0 1-1.088-.79l.72-4.194L.818 6.374a.75.75 0 0 1 .416-1.28l4.21-.611L7.327.668A.75.75 0 0 1 8 .25Z"/>
  </svg>
  <span class="wh-gh-count" data-repo={repo} aria-live="polite">—</span>
</a>

<script>
  (async () => {
    const el = document.querySelector('.wh-gh-count');
    if (!el) return;
    const repo = el.getAttribute('data-repo');
    const key = 'wh-gh-stars:' + repo;
    const TTL = 10 * 60 * 1000; // 10 min stale-while-revalidate
    const fmt = (n: number): string =>
      n >= 1000 ? (n / 1000).toFixed(n >= 10000 ? 0 : 1).replace(/\.0$/, '') + 'k' : String(n);

    let cached: { v: string; t: number } | null = null;
    try { cached = JSON.parse(sessionStorage.getItem(key) || 'null'); } catch {}
    if (cached && cached.v) el.textContent = cached.v;
    if (cached && Date.now() - cached.t < TTL) return; // fresh enough

    try {
      const res = await fetch('https://api.github.com/repos/' + repo, {
        headers: { Accept: 'application/vnd.github+json' },
      });
      if (!res.ok) throw new Error(String(res.status));
      const data: { stargazers_count?: number } = await res.json();
      if (typeof data.stargazers_count === 'number') {
        const v = fmt(data.stargazers_count);
        el.textContent = v;
        try { sessionStorage.setItem(key, JSON.stringify({ v, t: Date.now() })); } catch {}
      } else if (!cached) {
        el.textContent = 'Star';
      }
    } catch {
      if (!cached) el.textContent = 'Star';
    }
  })();
</script>

<style>
  .wh-gh {
    display: inline-flex;
    align-items: center;
    gap: 0.375rem;
    height: 32px;
    padding: 0 0.6rem;
    border: 1px solid var(--sl-color-gray-6);
    border-radius: 9999px;
    background: var(--sl-color-gray-7);
    color: var(--sl-color-gray-1);
    font-size: 0.8125rem;
    font-weight: 500;
    line-height: 1;
    text-decoration: none;
    white-space: nowrap;
    transition: border-color 0.15s ease, background 0.15s ease, color 0.15s ease;
  }
  .wh-gh:hover {
    border-color: var(--sl-color-gray-5);
    background: var(--sl-color-gray-6);
    color: var(--sl-color-white);
  }
  .wh-gh-mark {
    flex: none;
  }
  .wh-gh-star {
    flex: none;
    color: #f5a623; /* star amber — the one decorative pop on the chrome */
  }
  .wh-gh-count {
    font-variant-numeric: tabular-nums;
    min-width: 1.5ch;
    text-align: center;
  }
  /* On narrow headers, keep the mark + count, drop the star glyph. */
  @media (max-width: 50rem) {
    .wh-gh {
      padding: 0 0.5rem;
      gap: 0.3rem;
    }
    .wh-gh-star {
      display: none;
    }
  }
</style>
