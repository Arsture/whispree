--swiftversion 5.9
--indent 4
--indentcase true
--trimwhitespace always
--voidtype void
--wraparguments before-first
--wrapparameters before-first
--wrapcollections before-first
--closingparen balanced
--commas inline
--decimalgrouping 3,4
--semicolons never
--stripunusedargs closure-only
--maxwidth 150
--exclude DerivedData,.build,Whispree/Resources
